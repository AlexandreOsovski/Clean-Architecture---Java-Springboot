# ========================================
# PROJECT SETTINGS
# ========================================
PROJECT_NAME=clear_arch-backend
SPRING_PROFILES_ACTIVE=development
SPRING_DOCKER_COMPOSE_ENABLED=false

PORT=8080

# ⚠️ URLs internas (containers NÃO usam localhost)
BACKEND_URL=http://api:8080
FRONTEND_URL=http://frontend:8080

# Spring Application
spring.application.name=clean.arch

# ========================================
# POSTGRESQL DATABASE
# ========================================
POSTGRESQL_SERVER=postgres
POSTGRESQL_PORT_NUMBER=5432
POSTGRESQL_USER=alexandreosovski
POSTGRESQL_PASSWORD=
POSTGRESQL_DATABASE=clean_arch
POSTGRESQL_VOLUME=./.docker/.data/pg

# Spring Datasource
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/clean_arch
SPRING_DATASOURCE_USERNAME=${POSTGRESQL_USER}
SPRING_DATASOURCE_PASSWORD=${POSTGRESQL_PASSWORD}
SPRING_DATASOURCE_DRIVER_CLASS_NAME=org.postgresql.Driver

# Spring JPA
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_JPA_SHOW_SQL=true
SPRING_JPA_PROPERTIES_HIBERNATE_DIALECT=org.hibernate.dialect.PostgreSQLDialect

# ========================================
# JWT TOKENS
# ========================================
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRATION=3600000
JWT_REFRESH_EXPIRATION=86400000

# ========================================
# BUSINESS LOGIC TIMERS
# ========================================
MIN_SLEEP_BUSINESS_HOURS=10000
MAX_SLEEP_BUSINESS_HOURS=20000
MIN_SLEEP_AUTO_REPLY=4000
MAX_SLEEP_AUTO_REPLY=6000
MIN_SLEEP_INTERVAL=2000
MAX_SLEEP_INTERVAL=5000

# ========================================
# LOGGING
# ========================================
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_ORG_SPRINGFRAMEWORK_WEB=INFO
LOGGING_LEVEL_ORG_HIBERNATE_SQL=DEBUG